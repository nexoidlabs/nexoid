# Nexoid Hackathon Environment
# Copy to .env and fill in values

# Ethereum RPC
ETH_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
ETH_MAINNET_RPC_URL=https://ethereum-rpc.publicnode.com

# Deployer private key (NEVER commit real keys)
DEPLOYER_PRIVATE_KEY=

# Contract addresses (set after deployment)
IDENTITY_REGISTRY_ADDRESS=
DELEGATION_REGISTRY_ADDRESS=

# CLI environment
NEXOID_PRIVATE_KEY=
NEXOID_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
NEXOID_REGISTRY=
NEXOID_DELEGATION_REGISTRY=
NEXOID_SAFE=
NEXOID_TOKEN=

# WDK seed phrase (operator)
NEXOID_SEED_PHRASE=

# Next.js (nx-platform)
NEXT_PUBLIC_NETWORK=sepolia
NEXT_PUBLIC_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
NEXT_PUBLIC_REGISTRY_ADDRESS=
NEXT_PUBLIC_MODULE_ADDRESS=
