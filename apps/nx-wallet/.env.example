# LangGraph Configuration
# Configure these environment variables to connect to your LangGraph deployment

# The URL of your LangGraph deployment
EXPO_PUBLIC_LANGGRAPH_URL=http://localhost:8000

# Your LangGraph API key for authentication
EXPO_PUBLIC_LANGGRAPH_API_KEY=your_api_key_here

# The ID of the assistant/agent to use (defaults to 'agent')
EXPO_PUBLIC_LANGGRAPH_ASSISTANT_ID=agent
